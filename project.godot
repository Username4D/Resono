;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Nirvana"
run/main_scene="uid://bk055dmf6hucr"
config/features=PackedStringArray("4.6")

[autoload]

ui_transition_handler="*uid://blat3evgk3n5m"
safe_manager="*uid://ck1me73dunjtw"
audio_handler="*uid://jcgyntc18axc"

[editor_plugins]

enabled=PackedStringArray("res://addons/SmoothScroll/plugin.cfg", "res://addons/gdterm/plugin.cfg", "res://addons/godot_super-wakatime/plugin.cfg")

[file_customization]

